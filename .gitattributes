# Auto detect text files and perform LF normalization
* text=auto

# Source code
*.c text eol=lf
*.h text eol=lf
*.sql text eol=lf

# Documentation
*.md text eol=lf
*.txt text eol=lf
LICENSE text eol=lf

# Scripts
*.sh text eol=lf
Makefile text eol=lf

# Binary files
*.so binary
*.dylib binary
*.o binary
*.a binary

# Archives
*.tar binary
*.tar.gz binary
*.zip binary

# Images (if any)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary

